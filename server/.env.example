# Server
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/feed-frenzy
# For production: mongodb+srv://username:password@cluster.mongodb.net/feed-frenzy

# CORS
ALLOWED_ORIGINS=http://localhost:5173
# For production: ,yourdomain.com

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Feed Frenzy <noreply@feedfrenzy.com>

# Cron Jobs
SCRAPE_SCHEDULE=0 */4 * * *        # Every 4 hours
TREND_SCHEDULE=0 2 * * *           # Daily at 2 AM
NEWSLETTER_SCHEDULE=0 9 * * 0      # Sundays at 9 AM

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000        # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
```